" === Syntax & Colors ===
syntax on
filetype plugin indent on
set background=dark
colorscheme desert

" === UI ===
set number
set ruler
set laststatus=2
set showcmd
set showmatch
set cursorline
set wildmenu
set wildmode=longest:full,full
set scrolloff=5
set signcolumn=yes

" === Search ===
set hlsearch
set incsearch
set ignorecase
set smartcase

" === Indentation ===
set autoindent
set smartindent
set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4

" === Encoding & Files ===
set encoding=utf-8
set fileencoding=utf-8
set noswapfile
set nobackup
set nowritebackup
set hidden

" === Input ===
set backspace=indent,eol,start
set mouse=a
set ttimeoutlen=50

" === Performance ===
set ttyfast
set lazyredraw
